# Copy to .env and fill in.
#
# DATABASE_URL behavior:
# - Docker:  if unset, falls back to the in-cluster `postgres` service. Set it
#            here to point at a managed/external Postgres. Do NOT use `localhost`
#            (inside a container that is the container itself, not your machine).
# - Native:  required. Typically postgresql://localhost:5432/qmrdb on macOS.

OPENAI_API_KEY=
BASE_URL=http://localhost:8000
API_TOKEN=

# Postgres connection. Leave commented for Docker default; uncomment for native or external DB.
# DATABASE_URL=postgresql://localhost:5432/qmrdb

# Optional: LangGraph separate DB (defaults to DATABASE_URL)
# CHECKPOINT_DB_URL=

# Optional: LangSmith
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=
# LANGSMITH_ENDPOINT=

# Optional: Anthropic (not used by current graph, which is OpenAI-only)
# ANTHROPIC_API_KEY=
