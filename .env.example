# Copy to .env and fill in. For Docker Compose, DATABASE_URL is overridden in docker-compose.yml
# (app connects to the postgres service). For local dev, set DATABASE_URL to your machine.

OPENAI_API_KEY=
BASE_URL=http://localhost:8000
API_TOKEN=

# Optional: LangGraph separate DB (defaults to DATABASE_URL)
# CHECKPOINT_DB_URL=

# Optional: LangSmith
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=
# LANGSMITH_ENDPOINT=

# Optional: Anthropic (not used by current graph, which is OpenAI-only)
# ANTHROPIC_API_KEY=
